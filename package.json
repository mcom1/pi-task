{
  "name": "@heyhuynhgiabuu/pi-task",
  "version": "0.3.2",
  "description": "Delegating task/subagent extension for Pi: foreground/background subagents, widgets, tmux observability, SDK fallback.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pi-task": "dist/index.js"
  },
  "files": [
    "dist",
    "agents",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "media",
    "!media/demo-background-task.mp4"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "PI_XAI_SIDE_TOOLS=0 tsx --test test/helpers.test.ts test/prompt.test.ts test/frontmatter.test.ts test/renderHint.test.ts test/polling.test.ts test/taskWidget.test.ts test/sdkWidgetEvents.test.ts test/sdkBackground.test.ts test/sdkPolling.test.ts test/widgetLifecycle.test.ts test/handles.test.ts test/terminalBackend.test.ts test/herdrBackend.test.ts test/exitSentinel.test.ts test/waitCompletion.test.ts test/restore.test.ts test/lifecycleCompletion.test.ts test/failure-diagnostics.test.ts test/taskTitle.test.ts",
    "smoke": "PI_XAI_SIDE_TOOLS=0 tsx test/smoke.ts",
    "prepack": "npm run build",
    "postversion": "git push --follow-tags"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package",
    "agent",
    "subagent",
    "task",
    "tmux",
    "background-tasks",
    "parallel-execution",
    "session-management"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.0",
    "@earendil-works/pi-tui": "^0.80.0",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "video": "https://github.com/heyhuynhgiabuu/pi-task/releases/download/v0.2.0/demo-background-task.mp4",
    "image": "https://raw.githubusercontent.com/heyhuynhgiabuu/pi-task/main/media/demo.png"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyhuynhgiabuu/pi-task.git"
  },
  "bugs": {
    "url": "https://github.com/heyhuynhgiabuu/pi-task/issues"
  },
  "homepage": "https://github.com/heyhuynhgiabuu/pi-task#readme"
}
